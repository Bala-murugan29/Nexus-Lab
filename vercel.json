{
  "version": 2,
  "builds": [
    {
      "src": "apps/web/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/apps/web/$1"
    }
  ],
  "env": {
    "DATABASE_URL": "@database-url",
    "NEO4J_URI": "@neo4j-uri",
    "NEO4J_USER": "@neo4j-user",
    "NEO4J_PASSWORD": "@neo4j-password"
  },
  "build": {
    "env": {
      "DATABASE_URL": "@database-url"
    }
  }
}
